{
  "id": "grade4_1_recite",
  "name": "四年级上·背诵",
  "metadata": {
    "title": "部编版小学语文四年级上册",
    "subtitle": "必背古诗与课文"
  },
  "items": [
    {
      "id": "poem1",
      "type": "poem",
      "title": "浪淘沙（其一）",
      "author": "唐·刘禹锡",
      "unit": "第一单元",
      "lines": [
        "九曲黄河万里沙，",
        "浪淘风簸自天涯。",
        "如今直上银河去，",
        "同到牵牛织女家。"
      ]
    },
    {
      "id": "poem2",
      "type": "poem",
      "title": "鹿柴",
      "author": "唐·王维",
      "unit": "语文园地一",
      "lines": [
        "空山不见人，",
        "但闻人语响。",
        "返景入深林，",
        "复照青苔上。"
      ]
    },
    {
      "id": "poem3",
      "type": "poem",
      "title": "暮江吟",
      "author": "唐·白居易",
      "unit": "第三单元",
      "lines": [
        "一道残阳铺水中，",
        "半江瑟瑟半江红。",
        "可怜九月初三夜，",
        "露似真珠月似弓。"
      ]
    },
    {
      "id": "poem4",
      "type": "poem",
      "title": "题西林壁",
      "author": "宋·苏轼",
      "unit": "第三单元",
      "lines": [
        "横看成岭侧成峰，",
        "远近高低各不同。",
        "不识庐山真面目，",
        "只缘身在此山中。"
      ]
    },
    {
      "id": "poem5",
      "type": "poem",
      "title": "雪梅",
      "author": "宋·卢钺",
      "unit": "第三单元",
      "lines": [
        "梅雪争春未肯降，",
        "骚人阁笔费评章。",
        "梅须逊雪三分白，",
        "雪却输梅一段香。"
      ]
    },
    {
      "id": "poem6",
      "type": "poem",
      "title": "嫦娥",
      "author": "唐·李商隐",
      "unit": "语文园地四",
      "lines": [
        "云母屏风烛影深，",
        "长河渐落晓星沉。",
        "嫦娥应悔偷灵药，",
        "碧海青天夜夜心。"
      ]
    },
    {
      "id": "poem7",
      "type": "poem",
      "title": "出塞",
      "author": "唐·王昌龄",
      "unit": "第七单元",
      "lines": [
        "秦时明月汉时关，",
        "万里长征人未还。",
        "但使龙城飞将在，",
        "不教胡马度阴山。"
      ]
    },
    {
      "id": "poem8",
      "type": "poem",
      "title": "凉州词",
      "author": "唐·王翰",
      "unit": "第七单元",
      "lines": [
        "葡萄美酒夜光杯，",
        "欲饮琵琶马上催。",
        "醉卧沙场君莫笑，",
        "古来征战几人回？"
      ]
    },
    {
      "id": "poem9",
      "type": "poem",
      "title": "夏日绝句",
      "author": "宋·李清照",
      "unit": "第七单元",
      "lines": [
        "生当作人杰，",
        "死亦为鬼雄。",
        "至今思项羽，",
        "不肯过江东。"
      ]
    },
    {
      "id": "poem10",
      "type": "poem",
      "title": "别董大",
      "author": "唐·高适",
      "unit": "第七单元",
      "lines": [
        "千里黄云白日曛，",
        "北风吹雁雪纷纷。",
        "莫愁前路无知己，",
        "天下谁人不识君？"
      ]
    },
    {
      "id": "prose1",
      "type": "prose",
      "title": "精卫填海",
      "author": "《山海经》",
      "unit": "第四单元",
      "lines": [
        "炎帝之少女，名曰女娃。",
        "女娃游于东海，溺而不返，故为精卫，",
        "常衔西山之木石，以堙于东海。"
      ]
    },
    {
      "id": "prose2",
      "type": "prose",
      "title": "王戎不取道旁李",
      "author": "《世说新语》",
      "unit": "第八单元",
      "lines": [
        "王戎七岁，尝与诸小儿游。",
        "看道边李树多子折枝，诸儿竞走取之，唯戎不动。",
        "人问之，答曰：\"树在道边而多子，此必苦李。\"",
        "取之，信然。"
      ]
    },
    {
      "id": "prose3",
      "type": "prose",
      "title": "观潮（第3-4自然段）",
      "author": "赵宗成",
      "unit": "第一单元",
      "lines": [
        "午后一点左右，从远处传来隆隆的响声，好像闷雷滚动。",
        "顿时人声鼎沸，有人告诉我们，潮来了！",
        "我们踮着脚往东望去，江面还是风平浪静，看不出有什么变化。",
        "过了一会儿，响声越来越大，只见东边水天相接的地方出现了一条白线，人群又沸腾起来。",
        "那条白线很快地向我们移来，逐渐拉长，变粗，横贯江面。",
        "再近些，只见白浪翻滚，形成一堵两丈多高的水墙。",
        "浪潮越来越近，犹如千万匹白色战马齐头并进，浩浩荡荡地飞奔而来；",
        "那声音如同山崩地裂，好像大地都被震得颤动起来。"
      ]
    },
    {
      "id": "prose4",
      "type": "prose",
      "title": "走月亮（第4自然段）",
      "author": "吴然",
      "unit": "第一单元",
      "lines": [
        "细细的溪水，流着山草和野花的香味，流着月光。",
        "灰白色的鹅卵石，布满河床。",
        "哟，卵石间有多少可爱的小水塘啊，每个小水塘，都抱着一个月亮！",
        "哦，阿妈，白天你在溪里洗衣服吗？",
        "每个小水塘，都抱着一个月亮！",
        "阿妈，你白天在溪里洗衣服吗？",
        "每个小水塘，都抱着一个月亮。",
        "看，稻就要就要成熟了，稻穗低垂着头，稻田像一块月光镀亮的银毯。",
        "我们走过月光闪闪的溪岸，走过石拱桥；",
        "走过月影团团的果园，走过庄稼地和菜地……",
        "多么奇妙的夜晚啊，我和阿妈走月亮！"
      ]
    },
    {
      "id": "prose5",
      "type": "prose",
      "title": "日积月累·好问名言",
      "author": "古语警句",
      "unit": "语文园地二",
      "lines": [
        "好问则裕，自用则小。——《尚书》",
        "博学之，审问之，慎思之，明辨之，笃行之。——《礼记》",
        "智能之士，不学不成，不问不知。——[汉]王充",
        "人非生而知之者，孰能无惑？——[唐]韩愈"
      ]
    },
    {
      "id": "prose6",
      "type": "prose",
      "title": "日积月累·气象谚语",
      "author": "民间谚语",
      "unit": "语文园地三",
      "lines": [
        "立了秋，把扇丢。",
        "二八月，乱穿衣。",
        "夏雨少，秋霜早。",
        "八月里来雁门开，雁儿脚上带霜来。",
        "一场秋雨一场寒，十场秋雨要穿棉。",
        "八月暖，九月温，十月还有小阳春。"
      ]
    },
    {
      "id": "prose7",
      "type": "prose",
      "title": "日积月累·成语警句",
      "author": "古语警句",
      "unit": "语文园地六",
      "lines": [
        "尺有所短，寸有所长。",
        "机不可失，时不再来。",
        "差之毫厘，谬以千里。",
        "病从口入，祸从口出。",
        "一言既出，驷马难追。",
        "比上不足，比下有余。"
      ]
    },
    {
      "id": "prose8",
      "type": "prose",
      "title": "日积月累·描写人物",
      "author": "成语集锦",
      "unit": "语文园地八",
      "lines": [
        "眉清目秀 亭亭玉立 明眸皓齿 文质彬彬 相貌堂堂 威风凛凛",
        "膀大腰圆 浓眉大眼 白发苍苍 鹤发童颜 慈眉善目 步履蹒跚"
      ]
    }
  ]
}