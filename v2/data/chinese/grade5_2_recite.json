{
  "id": "grade5_2_recite",
  "name": "五年级下·背诵",
  "metadata": {
    "title": "部编版小学语文五年级下册",
    "subtitle": "必背古诗与课文"
  },
  "items": [
    {
      "id": "poem1",
      "type": "poem",
      "title": "四时田园杂兴（其三十一）",
      "author": "宋·范成大",
      "unit": "第一单元",
      "lines": [
        "昼出耘田夜绩麻，",
        "村庄儿女各当家。",
        "童孙未解供耕织，",
        "也傍桑阴学种瓜。"
      ]
    },
    {
      "id": "poem2",
      "type": "poem",
      "title": "稚子弄冰",
      "author": "宋·杨万里",
      "unit": "第一单元",
      "lines": [
        "稚子金盆脱晓冰，",
        "彩丝穿取当银钲。",
        "敲成玉磬穿林响，",
        "忽作玻璃碎地声。"
      ]
    },
    {
      "id": "poem3",
      "type": "poem",
      "title": "村晚",
      "author": "宋·雷震",
      "unit": "第一单元",
      "lines": [
        "草满池塘水满陂，",
        "山衔落日浸寒漪。",
        "牧童归去横牛背，",
        "短笛无腔信口吹。"
      ]
    },
    {
      "id": "poem4",
      "type": "poem",
      "title": "游子吟",
      "author": "唐·孟郊",
      "unit": "语文园地二",
      "lines": [
        "慈母手中线，",
        "游子身上衣。",
        "临行密密缝，",
        "意恐迟迟归。",
        "谁言寸草心，",
        "报得三春晖。"
      ]
    },
    {
      "id": "poem5",
      "type": "poem",
      "title": "鸟鸣涧",
      "author": "唐·王维",
      "unit": "语文园地二",
      "lines": [
        "人闲桂花落，",
        "夜静春山空。",
        "月出惊山鸟，",
        "时鸣春涧中。"
      ]
    },
    {
      "id": "poem6",
      "type": "poem",
      "title": "从军行",
      "author": "唐·王昌龄",
      "unit": "语文园地二",
      "lines": [
        "青海长云暗雪山，",
        "孤城遥望玉门关。",
        "黄沙百战穿金甲，",
        "不破楼兰终不还。"
      ]
    },
    {
      "id": "poem7",
      "type": "poem",
      "title": "秋夜将晓出篱门迎凉有感",
      "author": "宋·陆游",
      "unit": "第四单元",
      "lines": [
        "三万里河东入海，",
        "五千仞岳上摩天。",
        "遗民泪尽胡尘里，",
        "南望王师又一年。"
      ]
    },
    {
      "id": "poem8",
      "type": "poem",
      "title": "闻官军收河南河北",
      "author": "唐·杜甫",
      "unit": "第四单元",
      "lines": [
        "剑外忽传收蓟北，",
        "初闻涕泪满衣裳。",
        "却看妻子愁何在，",
        "漫卷诗书喜欲狂。",
        "白日放歌须纵酒，",
        "青春作伴好还乡。",
        "即从巴峡穿巫峡，",
        "便下襄阳向洛阳。"
      ]
    },
    {
      "id": "poem9",
      "type": "poem",
      "title": "凉州词",
      "author": "唐·王之涣",
      "unit": "语文园地四",
      "lines": [
        "黄河远上白云间，",
        "一片孤城万仞山。",
        "羌笛何须怨杨柳，",
        "春风不度玉门关。"
      ]
    },
    {
      "id": "poem10",
      "type": "poem",
      "title": "黄鹤楼送孟浩然之广陵",
      "author": "唐·李白",
      "unit": "语文园地四",
      "lines": [
        "故人西辞黄鹤楼，",
        "烟花三月下扬州。",
        "孤帆远影碧空尽，",
        "唯见长江天际流。"
      ]
    },
    {
      "id": "poem11",
      "type": "poem",
      "title": "乡村四月",
      "author": "宋·翁卷",
      "unit": "语文园地四",
      "lines": [
        "绿遍山原白满川，",
        "子规声里雨如烟。",
        "乡村四月闲人少，",
        "才了蚕桑又插田。"
      ]
    },
    {
      "id": "poem_yyjl1",
      "type": "poem",
      "title": "日积月累·为人处世",
      "author": "语文园地六",
      "unit": "语文园地六",
      "lines": [
        "君子喻于义，小人喻于利。——《论语》",
        "君子坦荡荡，小人长戚戚。——《论语》",
        "恻隐之心，仁之端也。——《孟子》",
        "多行不义，必自毙。——《左传》",
        "人有耻，则能有所不为。——《朱子语类》"
      ]
    },
    {
      "id": "poem_yyjl2",
      "type": "poem",
      "title": "日积月累·品行修养",
      "author": "语文园地八",
      "unit": "语文园地八",
      "lines": [
        "君子之修身，内正其心，外正其容。——欧阳修",
        "人生自古谁无死？留取丹心照汗青。——文天祥",
        "千磨万击还坚劲，任尔东西南北风。——郑燮",
        "不要人夸好颜色，只留清气满乾坤。——王冕"
      ]
    },
    {
      "id": "poem_yyjl3",
      "type": "poem",
      "title": "日积月累·汉字故事",
      "author": "语文园地三",
      "unit": "语文园地三",
      "lines": [
        "汉字谐音的妙用：",
        "外甥打灯笼——照旧（舅）",
        "孔夫子搬家——净是输（书）",
        "小葱拌豆腐——一清二白（青）",
        "上鞋不用锥子——真（针）好",
        "四月的冰河——开动（冻）了",
        "隔着门缝吹喇叭——名（鸣）声在外"
      ]
    },
    {
      "id": "poem_yyjl4",
      "type": "poem",
      "title": "日积月累·描写儿童诗句",
      "author": "语文园地一",
      "unit": "语文园地一",
      "lines": [
        "稚子弄冰——[宋]杨万里：稚子金盆脱晓冰，彩丝穿取当银钲。",
        "村晚——[宋]雷震：牧童归去横牛背，短笛无腔信口吹。",
        "四时田园杂兴——[宋]范成大：童孙未解供耕织，也傍桑阴学种瓜。",
        "清平乐·村居——[宋]辛弃疾：最喜小儿亡赖，溪头卧剥莲蓬。"
      ]
    },
    {
      "id": "prose1",
      "type": "prose",
      "title": "自相矛盾",
      "author": "《韩非子》",
      "unit": "第六单元",
      "lines": [
        "楚人有鬻盾与矛者，誉之曰：\"吾盾之坚，物莫能陷也。\"",
        "又誉其矛曰：\"吾矛之利，于物无不陷也。\"",
        "或曰：\"以子之矛陷子之盾，何如？\"",
        "其人弗能应也。",
        "夫不可陷之盾与无不陷之矛，不可同世而立。"
      ]
    },
    {
      "id": "prose2",
      "type": "prose",
      "title": "杨氏之子",
      "author": "《世说新语》",
      "unit": "第八单元",
      "lines": [
        "梁国杨氏子九岁，甚聪惠。",
        "孔君平诣其父，父不在，乃呼儿出。",
        "为设果，果有杨梅。",
        "孔指以示儿曰：\"此是君家果。\"",
        "儿应声答曰：\"未闻孔雀是夫子家禽。\""
      ]
    }
  ]
}
