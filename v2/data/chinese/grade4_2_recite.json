{
  "id": "grade4_2_recite",
  "name": "四年级下·背诵",
  "metadata": {
    "title": "部编版小学语文四年级下册",
    "subtitle": "必背古诗与课文"
  },
  "items": [
    {
      "id": "poem1",
      "type": "poem",
      "title": "宿新市徐公店",
      "author": "宋·杨万里",
      "unit": "第一单元",
      "lines": [
        "篱落疏疏一径深，",
        "树头新绿未成阴。",
        "儿童急走追黄蝶，",
        "飞入菜花无处寻。"
      ]
    },
    {
      "id": "poem2",
      "type": "poem",
      "title": "四时田园杂兴（其二十五）",
      "author": "宋·范成大",
      "unit": "第一单元",
      "lines": [
        "梅子金黄杏子肥，",
        "麦花雪白菜花稀。",
        "日长篱落无人过，",
        "惟有蜻蜓蛱蝶飞。"
      ]
    },
    {
      "id": "poem3",
      "type": "poem",
      "title": "清平乐·村居",
      "author": "宋·辛弃疾",
      "unit": "第一单元",
      "lines": [
        "茅檐低小，溪上青青草。",
        "醉里吴音相媚好，白发谁家翁媪？",
        "大儿锄豆溪东，中儿正织鸡笼。",
        "最喜小儿亡赖，溪头卧剥莲蓬。"
      ]
    },
    {
      "id": "poem4",
      "type": "poem",
      "title": "卜算子·咏梅",
      "author": "毛泽东",
      "unit": "第三单元",
      "lines": [
        "风雨送春归，飞雪迎春到。",
        "已是悬崖百丈冰，犹有花枝俏。",
        "俏也不争春，只把春来报。",
        "待到山花烂漫时，她在丛中笑。"
      ]
    },
    {
      "id": "poem5",
      "type": "poem",
      "title": "江畔独步寻花",
      "author": "唐·杜甫",
      "unit": "第三单元",
      "lines": [
        "黄师塔前江水东，春光懒困倚微风。",
        "桃花一簇开无主，可爱深红爱浅红？"
      ]
    },
    {
      "id": "poem6",
      "type": "poem",
      "title": "蜂",
      "author": "唐·罗隐",
      "unit": "第三单元",
      "lines": [
        "不论平地与山尖，",
        "无限风光尽被占。",
        "采得百花成蜜后，",
        "为谁辛苦为谁甜？"
      ]
    },
    {
      "id": "poem7",
      "type": "poem",
      "title": "独坐敬亭山",
      "author": "唐·李白",
      "unit": "第七单元",
      "lines": [
        "众鸟高飞尽，",
        "孤云独去闲。",
        "相看两不厌，",
        "只有敬亭山。"
      ]
    },
    {
      "id": "poem8",
      "type": "poem",
      "title": "芙蓉楼送辛渐",
      "author": "唐·王昌龄",
      "unit": "第七单元",
      "lines": [
        "寒雨连江夜入吴，",
        "平明送客楚山孤。",
        "洛阳亲友如相问，",
        "一片冰心在玉壶。"
      ]
    },
    {
      "id": "poem9",
      "type": "poem",
      "title": "塞下曲",
      "author": "唐·卢纶",
      "unit": "第七单元",
      "lines": [
        "月黑雁飞高，",
        "单于夜遁逃。",
        "欲将轻骑逐，",
        "大雪满弓刀。"
      ]
    },
    {
      "id": "poem10",
      "type": "poem",
      "title": "墨梅",
      "author": "元·王冕",
      "unit": "第七单元",
      "lines": [
        "我家洗砚池头树，",
        "朵朵花开淡墨痕。",
        "不要人夸好颜色，",
        "只留清气满乾坤。"
      ]
    },
    {
      "id": "prose1",
      "type": "prose",
      "title": "囊萤夜读",
      "author": "《晋书》",
      "unit": "第七单元",
      "lines": [
        "胤恭勤不倦，博学多通。",
        "家贫不常得油，夏月，则练囊盛数十萤火以照书，以夜继日焉。"
      ]
    },
    {
      "id": "prose2",
      "type": "prose",
      "title": "铁杵成针",
      "author": "《方舆胜览》",
      "unit": "第七单元",
      "lines": [
        "磨针溪，在象耳山下。",
        "世传李白读书山中，未成，弃去。",
        "过是溪，逢老媪方磨铁杵。",
        "问之，曰：\"欲作针。\"",
        "太白感其意，还卒业。"
      ]
    },
    {
      "id": "prose3",
      "type": "prose",
      "title": "绿",
      "author": "艾青",
      "unit": "第三单元",
      "lines": [
        "好像绿色的墨水瓶倒翻了，",
        "到处是绿的......",
        "到哪儿去找这么多的绿：",
        "墨绿、嫩绿、淡绿、粉绿......",
        "绿得发黑、绿得出奇。",
        "刮的风是绿的，",
        "下的雨是绿的，",
        "流的水是绿的，",
        "阳光也是绿的。",
        "所有的绿集中起来，",
        "挤在一起，",
        "重叠在一起，",
        "静静地交叉在一起。",
        "突然一阵风，",
        "好像舞蹈教练在指挥，",
        "所有的绿就整齐地",
        "按着节拍飘动在一起......"
      ]
    },
    {
      "id": "prose4",
      "type": "prose",
      "title": "繁星（七一）",
      "author": "冰心",
      "unit": "第三单元",
      "lines": [
        "这些事——",
        "是永不漫灭的回忆：",
        "月明的园中，",
        "藤萝的叶下，",
        "母亲的膝上。"
      ]
    },
    {
      "id": "prose5",
      "type": "prose",
      "title": "繁星（一三一）",
      "author": "冰心",
      "unit": "第三单元",
      "lines": [
        "大海啊！",
        "哪一颗星没有光？",
        "哪一朵花没有香？",
        "哪一次我的思潮里",
        "没有你波涛的清响？"
      ]
    },
    {
      "id": "prose6",
      "type": "prose",
      "title": "繁星（一五九）",
      "author": "冰心",
      "unit": "第三单元",
      "lines": [
        "母亲啊！",
        "天上的风雨来了，",
        "鸟儿躲到它的巢里；",
        "心中的风雨来了，",
        "我只躲到你的怀里。"
      ]
    },
    {
      "id": "prose7",
      "type": "prose",
      "title": "日积月累·对联",
      "author": "对联集锦",
      "unit": "语文园地二",
      "lines": [
        "白马西风塞上，杏花烟雨江南。",
        "雾锁山头山锁雾，天连水尾水连天。",
        "清风明月本无价，近水远山皆有情。",
        "四面荷花三面柳，一城山色半城湖。"
      ]
    },
    {
      "id": "prose8",
      "type": "prose",
      "title": "日积月累·诗名言",
      "author": "名人语录",
      "unit": "语文园地三",
      "lines": [
        "诗是人类向未来寄发的信息，诗给人类以朝向理想的勇气。——艾青",
        "诗和音乐一样，生命全在节奏。——朱光潜",
        "诗是强烈感情的自然流露，它源于宁静中回忆起来的情感。——[英]华兹华斯"
      ]
    },
    {
      "id": "prose9",
      "type": "prose",
      "title": "日积月累·自强不息",
      "author": "古语警句",
      "unit": "语文园地七",
      "lines": [
        "天行健，君子以自强不息。——《周易》",
        "胜人者有力，自胜者强。——《老子》",
        "不怨天，不尤人。——《论语》",
        "生于忧患而死于安乐。——《孟子》"
      ]
    },
    {
      "id": "prose10",
      "type": "prose",
      "title": "日积月累·读书名言",
      "author": "古语警句",
      "unit": "语文园地八",
      "lines": [
        "少年不知勤学苦，老来方知读书迟。",
        "一日读书一日功，一日不读十日空。",
        "学习不怕根底浅，只要迈步总不迟。",
        "书山有路勤为径，学海无涯苦作舟。"
      ]
    }
  ]
}