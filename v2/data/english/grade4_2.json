        {"word": "sky", "chinese": "天空", "phonetic": "/skaɪ/", "audio": "sky"},
        {"word": "moon", "chinese": "月亮", "phonetic": "/muːn/", "audio": "moon"},
        {"word": "noon", "chinese": "中午", "phonetic": "/nuːn/", "audio": "noon"},
        {"word": "evening", "chinese": "傍晚", "phonetic": "/ˈiːvnɪŋ/", "audio": "evening"},
        {"word": "night", "chinese": "夜晚", "phonetic": "/naɪt/", "audio": "night"},
        {"word": "high", "chinese": "高的", "phonetic": "/haɪ/", "audio": "high"},
        {"word": "go down", "chinese": "落下", "phonetic": "/ɡəʊ daʊn/", "audio": "go down"},
        {"word": "stop", "chinese": "停下", "phonetic": "/stɒp/", "audio": "stop"},
        {"word": "take a walk", "chinese": "散步", "phonetic": "/teɪk ə wɔːk/", "audio": "take a walk"}
      ],
      "sentences": [
        {"english": "Look at the sky. What can you see?", "chinese": "看天空。你能看见什么？"},
        {"english": "I can see the moon and stars.", "chinese": "我能看见月亮和星星。"},
        {"english": "The sun rises in the morning.", "chinese": "太阳在早上升起。"},
        {"english": "The shadow is long in the evening.", "chinese": "傍晚时影子很长。"}
      ],
      "grammar": [
        {"type": "sentence_reorder", "question": "can / you / What / see / ?", "answer": "What can you see?", "explanation": "询问能看见什么：What + can + 主语 + see?"},
        {"type": "sentence_reorder", "question": "moon / can / I / see / the / stars / and / .", "answer": "I can see the moon and stars.", "explanation": "回答：I can see + 名词。用and连接多个名词。"},
        {"type": "logic_match", "question": "将时间与影子长度配对：morning, noon, evening, long shadow, short shadow", "answer": "morning↔long shadow, noon↔short shadow, evening↔long shadow", "explanation": "太阳位置低时影子长，位置高时影子短。"},
        {"type": "context_fill", "question": "The sun _____ (rise/rises) in the east every morning.", "answer": "rises", "explanation": "太阳升起是自然规律，用一般现在时第三人称单数。"}
      ]
    },
