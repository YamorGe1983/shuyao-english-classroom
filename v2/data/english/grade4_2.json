  "grammar": {
    "choiceQuestions": {
      "basic": [
        {
          "id": "g4b_b_01",
          "question": "The wool ___ soft and warm.",
          "options": [
            "feels",
            "feel",
            "felt"
          ],
          "answer": 0,
          "explanation": "感官动词feel表示'摸起来'，主语是wool单数，用feels。第三人称单数现在时。"
        },
        {
          "id": "g4b_b_02",
          "question": "Is it sweet ___ sour?",
          "options": [
            "or",
            "and",
            "but"
          ],
          "answer": 0,
          "explanation": "选择疑问句用or连接两个选项。and表并列，but表转折。"
        },
        {
          "id": "g4b_b_03",
          "question": "What can you ___?",
          "options": [
            "look",
            "see",
            "look at"
          ],
          "answer": 1,
          "explanation": "see强调看到的结果，look强调看的动作。学生易混淆两者：look是不及物动词，后接宾语需加at。"
        },
        {
          "id": "g4b_b_04",
          "question": "The blind man ___ see.",
          "options": [
            "can't",
            "cannot",
            "doesn't"
          ],
          "answer": 0,
          "explanation": "blind表示看不见，用can't。cannot可分开写但意思相同，doesn't需要接动词原形但表意不准确。"
        },
        {
          "id": "g4b_b_05",
          "question": "We have Art and Music ___ Monday.",
          "options": [
            "on",
            "in",
            "at"
          ],
          "answer": 0,
          "explanation": "星期几用介词on。Monday是具体日期，in用于月份/年份，at用于具体时刻。"
        },
        {
          "id": "g4b_b_06",
          "question": "I usually get up ___ 7 o'clock.",
          "options": [
            "at",
            "in",
            "on"
          ],
          "answer": 0,
          "explanation": "具体时刻用介词at。7 o'clock是具体时间点，in用于较长时段，on用于具体日期。"
        },
        {
          "id": "g4b_b_07",
          "question": "I play ___ football every day.",
          "options": [
            "-",
            "the",
            "a"
          ],
          "answer": 0,
          "explanation": "球类运动前不加冠词。football是球类运动，不是乐器或特定物体。"
        },
        {
          "id": "g4b_b_08",
          "question": "She plays ___ piano very well.",
          "options": [
            "the",
            "-",
            "a"
          ],
          "answer": 0,
          "explanation": "乐器前要加the。piano是乐器，与球类运动不同，需加定冠词the。"
        },
        {
          "id": "g4b_b_09",
          "question": "___ bag is this? It's mine.",
          "options": [
            "Whose",
            "Who",
            "Who's"
          ],
          "answer": 0,
          "explanation": "Whose询问物品归属，Who询问人物身份。Whose是所有格，后接名词。"
        },
        {
          "id": "g4b_b_10",
          "question": "The book is ___ the bag.",
          "options": [
            "in",
            "on",
            "to"
          ],
          "answer": 0,
          "explanation": "in表示在...里面（在里面）。on表示在...上面，to表示方向，此处表示书在包里。"
        }
      ],
      "improved": [
        {
          "id": "g4b_i_01",
          "question": "I have Music ___ Tuesday.",
          "options": [
            "on",
            "in",
            "at"
          ],
          "answer": 0,
          "explanation": "具体星期几用介词on。学生常误用in Tuesday（受中文影响）。"
        },
        {
          "id": "g4b_i_02",
          "question": "There are ___ days in a week.",
          "options": [
            "seven",
            "second",
            "seventh"
          ],
          "answer": 0,
          "explanation": "一周有七天，用基数词seven表示数量。second/seventh是序数词。"
        },
        {
          "id": "g4b_i_03",
          "question": "I wake up ___ 6 o'clock ___ the morning.",
          "options": [
            "at, in",
            "in, in",
            "on, in"
          ],
          "answer": 0,
          "explanation": "具体时刻用at，上午/下午/晚上用in。6 o'clock是时刻，morning是时段。"
        },
        {
          "id": "g4b_i_04",
          "question": "The piano is ___ the window.",
          "options": [
            "next to",
            "next",
            "next of"
          ],
          "answer": 0,
          "explanation": "next to表示'紧挨着'，是固定搭配。next是形容词单独使用时不完整。"
        },
        {
          "id": "g4b_i_05",
          "question": "Whose books are ___?",
          "options": [
            "these",
            "this",
            "that"
          ],
