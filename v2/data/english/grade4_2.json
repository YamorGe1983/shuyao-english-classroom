    "unit1": {
      "id": "unit1",
      "module": "module1",
      "name": "Touch and feel",
      "nameCN": "触摸与感觉",
      "topic": "学习触觉形容词和感官动词",
      "vocabulary": [
        {"word": "touch", "chinese": "触摸", "phonetic": "/tʌtʃ/", "audio": "touch"},
        {"word": "feel", "chinese": "感觉/摸起来", "phonetic": "/fiːl/", "audio": "feel"},
        {"word": "soft", "chinese": "柔软的", "phonetic": "/sɒft/", "audio": "soft"},
        {"word": "hard", "chinese": "坚硬的", "phonetic": "/hɑːd/", "audio": "hard"},
        {"word": "thick", "chinese": "厚的/粗的", "phonetic": "/θɪk/", "audio": "thick"},
        {"word": "thin", "chinese": "薄的/细的", "phonetic": "/θɪn/", "audio": "thin"},
        {"word": "smooth", "chinese": "光滑的", "phonetic": "/smuːð/", "audio": "smooth"},
        {"word": "rough", "chinese": "粗糙的", "phonetic": "/rʌf/", "audio": "rough"},
        {"word": "blind", "chinese": "瞎的", "phonetic": "/blaɪnd/", "audio": "blind"},
        {"word": "noise", "chinese": "噪音", "phonetic": "/nɔɪz/", "audio": "noise"},
        {"word": "young", "chinese": "年轻的", "phonetic": "/jʌŋ/", "audio": "young"}
      ],
      "sentences": [
        {"english": "Touch this. How does it feel?", "chinese": "摸摸这个。它感觉怎么样？"},
        {"english": "It's soft and smooth.", "chinese": "它又软又光滑。"},
        {"english": "Is it hard or soft?", "chinese": "它是硬的还是软的？"},
        {"english": "The blind man can't see.", "chinese": "盲人看不见。"}
      ],
      "grammar": [
        {"type": "sentence_reorder", "question": "it / feel / does / How / ?", "answer": "How does it feel?", "explanation": "询问触觉感受：How + does + 主语 + feel?"},
        {"type": "sentence_reorder", "question": "soft / is / It / smooth / and / .", "answer": "It is soft and smooth.", "explanation": "描述触觉特征：It is + 形容词。"},
        {"type": "logic_match", "question": "将形容词与反义词配对：soft, hard, thick, thin, smooth, rough", "answer": "soft↔hard, thick↔thin, smooth↔rough", "explanation": "触觉形容词有三对反义词，记住它们可以帮助理解。"},
        {"type": "context_fill", "question": "The pineapple is _____ (hard/soft). You can't squeeze it.", "answer": "hard", "explanation": "菠萝摸起来是硬的，不能挤压。"}
      ]
    },
    "unit2": {
      "id": "unit2",
      "module": "module1",
      "name": "Smell and taste",
      "nameCN": "闻与尝",
      "topic": "学习嗅觉和味觉词汇",
      "vocabulary": [
        {"word": "smell", "chinese": "闻", "phonetic": "/smel/", "audio": "smell"},
        {"word": "taste", "chinese": "尝", "phonetic": "/teɪst/", "audio": "taste"},
        {"word": "strawberry", "chinese": "草莓", "phonetic": "/ˈstrɔːbəri/", "audio": "strawberry"},
        {"word": "watermelon", "chinese": "西瓜", "phonetic": "/ˈwɔːtəmelən/", "audio": "watermelon"},
        {"word": "grape", "chinese": "葡萄", "phonetic": "/ɡreɪp/", "audio": "grape"},
        {"word": "fox", "chinese": "狐狸", "phonetic": "/fɒks/", "audio": "fox"},
        {"word": "sweet", "chinese": "甜的", "phonetic": "/swiːt/", "audio": "sweet"},
        {"word": "sour", "chinese": "酸的", "phonetic": "/saʊə/", "audio": "sour"},
        {"word": "round", "chinese": "圆的", "phonetic": "/raʊnd/", "audio": "round"},
        {"word": "purple", "chinese": "紫色的", "phonetic": "/ˈpɜːpl/", "audio": "purple"},
        {"word": "wait", "chinese": "等待", "phonetic": "/weɪt/", "audio": "wait"},
        {"word": "minute", "chinese": "分钟", "phonetic": "/ˈmɪnɪt/", "audio": "minute"},
        {"word": "get", "chinese": "得到", "phonetic": "/ɡet/", "audio": "get"}
      ],
      "sentences": [
        {"english": "Smell this. Is it a strawberry?", "chinese": "闻闻这个。是草莓吗？"},
        {"english": "Taste it. Is it sweet or sour?", "chinese": "尝尝它。是甜的还是酸的？"},
        {"english": "It's sweet and yummy.", "chinese": "它是甜的，很好吃。"},
        {"english": "Wait a minute, please.", "chinese": "请等一下。"}
      ],
      "grammar": [
        {"type": "sentence_reorder", "question": "it / sweet / Is / sour / or / ?", "answer": "Is it sweet or sour?", "explanation": "选择疑问句：Is it + A or B? 用or连接两个选项。"},
        {"type": "sentence_reorder", "question": "this / Smell / . / a / Is / it / strawberry / ?", "answer": "Smell this. Is it a strawberry?", "explanation": "祈使句开头：动词原形开头，表示请求或命令。"},
        {"type": "logic_match", "question": "将水果与颜色/味道配对：strawberry, watermelon, grape, sweet, sour, purple, red, green", "answer": "strawberry↔red↔sweet, watermelon↔green↔sweet, grape↔purple↔sweet/sour", "explanation": "不同的水果有不同的颜色和味道特征。"},
        {"type": "context_fill", "question": "The lemon is _____. I don't like it. (sweet/sour)", "answer": "sour", "explanation": "柠檬是酸的，很多人不喜欢酸味。"}
      ]
    },
