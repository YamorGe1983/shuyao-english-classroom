  "grammar": {
    "choiceQuestions": {
      "basic": [
        {
          "id": "g5b_b_01",
          "question": "It ___ an egg yesterday.",
          "options": [
            "was",
            "is",
            "are"
          ],
          "answer": 0,
          "explanation": "yesterday表示过去，用was。学生常忘记使用过去式，或混淆be动词的过去形式。"
        },
        {
          "id": "g5b_b_02",
          "question": "They ___ happy last week.",
          "options": [
            "were",
            "was",
            "are"
          ],
          "answer": 0,
          "explanation": "复数主语(They)过去时用were。was用于单数，are是现在时。last week提示过去时间。"
        },
        {
          "id": "g5b_b_03",
          "question": "I ___ a nice dinner yesterday evening.",
          "options": [
            "had",
            "have",
            "has"
          ],
          "answer": 0,
          "explanation": "yesterday evening表示过去，用过去式had。学生常忘记变化或误用has（第三人称单数现在时）。"
        },
        {
          "id": "g5b_b_04",
          "question": "He ___ to school by bus yesterday.",
          "options": [
            "went",
            "goed",
            "goes"
          ],
          "answer": 0,
          "explanation": "go的过去式是went，是不规则变化。goed不是正确形式，goes是现在时态。Yesterday提示用过去式。"
        },
        {
          "id": "g5b_b_05",
          "question": "The bread ___ five yuan yesterday.",
          "options": [
            "was",
            "is",
            "were"
          ],
          "answer": 0,
          "explanation": "bread是不可数名词作主语，用was。yesterday提示过去时。were用于复数主语。"
        },
        {
          "id": "g5b_b_06",
          "question": "It ___ snowing heavily last night.",
          "options": [
            "was",
            "is",
            "were"
          ],
          "answer": 0,
          "explanation": "It + 天气/温度结构用was。last night提示过去时间。学生可能混淆为there be句型用were。"
        },
        {
          "id": "g5b_b_07",
          "question": "Halloween is ___ October 31st.",
          "options": [
            "on",
            "in",
            "at"
