        {"word": "healthy", "chinese": "健康的", "phonetic": "/ˈhelθi/", "audio": "healthy"},
        {"word": "had", "chinese": "吃/有(have的过去式)", "phonetic": "/hæd/", "audio": "had"},
        {"word": "did", "chinese": "做(do的过去式)", "phonetic": "/dɪd/", "audio": "did"},
        {"word": "keep...away", "chinese": "远离", "phonetic": "/kiːp əˈweɪ/", "audio": "keep away"}
      ],
      "sentences": [
        {"english": "What did you have for breakfast?", "chinese": "你早饭吃了什么？"},
        {"english": "I had some bread and milk.", "chinese": "我吃了一些面包和牛奶。"},
        {"english": "Is it healthy?", "chinese": "它健康吗？"},
        {"english": "An apple a day keeps the doctor away.", "chinese": "一天一个苹果，医生远离我。"}
      ],
      "grammar": [
        {"type": "sentence_reorder", "question": "did / What / you / have / for breakfast / ?", "answer": "What did you have for breakfast?", "explanation": "过去时疑问句：What did + 主语 + 动词原形?"},
        {"type": "sentence_reorder", "question": "had / I / some / bread / and / milk / .", "answer": "I had some bread and milk.", "explanation": "过去时回答：主语 + had + 食物。have的过去式是had。"},
        {"type": "logic_match", "question": "将食物与类别配对：pork, beef, chicken, tomato, potato, carrot, meat, vegetable", "answer": "pork, beef, chicken↔meat, tomato, potato, carrot↔vegetable", "explanation": "肉类和蔬菜是两大类食物。"},
        {"type": "context_fill", "question": "I _____ (have/had) some fish and vegetables for dinner yesterday.", "answer": "had", "explanation": "yesterday表示过去，用过去式had。"}
      ]
    },
