    "unit1": {
      "id": "unit1",
      "module": "module1",
      "name": "Tidy up!",
      "nameCN": "整理！",
      "topic": "学习物主代词和整理词汇",
      "vocabulary": [
        {"word": "tidy", "chinese": "整洁的", "phonetic": "/ˈtaɪdi/", "audio": "tidy"},
        {"word": "sock", "chinese": "短袜", "phonetic": "/sɒk/", "audio": "sock"},
        {"word": "cap", "chinese": "帽子", "phonetic": "/kæp/", "audio": "cap"},
        {"word": "crayon", "chinese": "蜡笔", "phonetic": "/ˈkreɪən/", "audio": "crayon"},
        {"word": "umbrella", "chinese": "雨伞", "phonetic": "/ʌmˈbrelə/", "audio": "umbrella"},
        {"word": "mine", "chinese": "我的", "phonetic": "/maɪn/", "audio": "mine"},
        {"word": "yours", "chinese": "你的", "phonetic": "/jɔːz/", "audio": "yours"},
        {"word": "hers", "chinese": "她的", "phonetic": "/hɜːz/", "audio": "hers"},
        {"word": "theirs", "chinese": "他们的", "phonetic": "/ðeəz/", "audio": "theirs"},
        {"word": "tidy up", "chinese": "整理", "phonetic": "/ˈtaɪdi ʌp/", "audio": "tidy up"},
        {"word": "put", "chinese": "放", "phonetic": "/pʊt/", "audio": "put"},
        {"word": "let", "chinese": "让", "phonetic": "/let/", "audio": "let"}
      ],
      "sentences": [
        {"english": "What a mess!", "chinese": "真乱啊！"},
        {"english": "Whose sock is this?", "chinese": "这是谁的袜子？"},
        {"english": "It's mine.", "chinese": "是我的。"},
        {"english": "Put it on the bed.", "chinese": "把它放在床上。"}
      ],
      "grammar": [
        {"type": "sentence_reorder", "question": "sock / Whose / is / this / ?", "answer": "Whose sock is this?", "explanation": "询问归属：Whose + 名词 + is this?"},
        {"type": "sentence_reorder", "question": "mine / It's / .", "answer": "It's mine.", "explanation": "用名词性物主代词回答：It's + mine/yours/his/hers。"},
        {"type": "logic_match", "question": "将形容词性物主代词与名词性物主代词配对：my, your, her, their, mine, yours, hers, theirs", "answer": "my↔mine, your↔yours, her↔hers, their↔theirs", "explanation": "形容词性物主代词后接名词，名词性物主代词单独使用。"},
        {"type": "context_fill", "question": "This is _____ (my/mine) book. The book is _____ (my/mine).", "answer": "my, mine", "explanation": "my后接名词，mine单独使用。"}
      ]
    },
    "unit2": {
      "id": "unit2",
      "module": "module1",
      "name": "Watch it grow",
      "nameCN": "观察生长",
      "topic": "学习动物生命周期和过去时",
      "vocabulary": [
        {"word": "egg", "chinese": "蛋", "phonetic": "/eɡ/", "audio": "egg"},
        {"word": "caterpillar", "chinese": "毛毛虫", "phonetic": "/ˈkætəpɪlə/", "audio": "caterpillar"},
        {"word": "cocoon", "chinese": "茧", "phonetic": "/kəˈkuːn/", "audio": "cocoon"},
        {"word": "butterfly", "chinese": "蝴蝶", "phonetic": "/ˈbʌtəflaɪ/", "audio": "butterfly"},
        {"word": "chicken", "chinese": "小鸡", "phonetic": "/ˈtʃɪkɪn/", "audio": "chicken"},
        {"word": "duckling", "chinese": "小鸭", "phonetic": "/ˈdʌklɪŋ/", "audio": "duckling"},
        {"word": "puppy", "chinese": "小狗", "phonetic": "/ˈpʌpi/", "audio": "puppy"},
        {"word": "grow", "chinese": "生长", "phonetic": "/ɡrəʊ/", "audio": "grow"},
        {"word": "fly", "chinese": "飞", "phonetic": "/flaɪ/", "audio": "fly"},
        {"word": "was", "chinese": "是(is/am的过去式)", "phonetic": "/wɒz/", "audio": "was"},
        {"word": "were", "chinese": "是(are的过去式)", "phonetic": "/wɜː/", "audio": "were"}
      ],
      "sentences": [
        {"english": "It was an egg.", "chinese": "它过去是一个蛋。"},
        {"english": "Now it is a caterpillar.", "chinese": "现在它是一只毛毛虫。"},
        {"english": "Do you know how it grows?", "chinese": "你知道它是怎么长大的吗？"},
        {"english": "It was a caterpillar. Now it is a butterfly.", "chinese": "它过去是毛毛虫。现在是蝴蝶。"}
      ],
      "grammar": [
        {"type": "sentence_reorder", "question": "was / It / an / egg / .", "answer": "It was an egg.", "explanation": "过去时描述：主语 + was/were + 名词/形容词。was用于单数，were用于复数。"},
        {"type": "sentence_reorder", "question": "is / Now / it / a / caterpillar / .", "answer": "Now it is a caterpillar.", "explanation": "现在时描述：Now + 主语 + is + 名词。"},
        {"type": "logic_match", "question": "将动物与生长阶段配对：butterfly, chicken, duck, egg, caterpillar, cocoon, chick, duckling", "answer": "butterfly: egg→caterpillar→cocoon→butterfly, chicken: egg→chick, duck: egg→duckling", "explanation": "不同动物有不同的生长过程。"},
        {"type": "context_fill", "question": "They _____ (was/were) small. Now they are big.", "answer": "were", "explanation": "复数用were，单数用was。"}
      ]
    },
    "unit3": {
      "id": "unit3",
      "module": "module1",
      "name": "How noisy!",
      "nameCN": "好吵啊！",
      "topic": "学习噪音词汇和过去时",
      "vocabulary": [
        {"word": "drill", "chinese": "钻孔机", "phonetic": "/drɪl/", "audio": "drill"},
        {"word": "lorry", "chinese": "卡车", "phonetic": "/ˈlɒri/", "audio": "lorry"},
        {"word": "bus", "chinese": "公共汽车", "phonetic": "/bʌs/", "audio": "bus"},
        {"word": "car", "chinese": "小汽车", "phonetic": "/kɑː/", "audio": "car"},
        {"word": "motorbike", "chinese": "摩托车", "phonetic": "/ˈməʊtəbaɪk/", "audio": "motorbike"},
        {"word": "noise", "chinese": "噪音", "phonetic": "/nɔɪz/", "audio": "noise"},
        {"word": "hear", "chinese": "听见", "phonetic": "/hɪə/", "audio": "hear"},
        {"word": "heard", "chinese": "听见(过去式)", "phonetic": "/hɜːd/", "audio": "heard"},
        {"word": "sit", "chinese": "坐", "phonetic": "/sɪt/", "audio": "sit"},
        {"word": "sat", "chinese": "坐(过去式)", "phonetic": "/sæt/", "audio": "sat"},
        {"word": "loud", "chinese": "大声的", "phonetic": "/laʊd/", "audio": "loud"},
        {"word": "quiet", "chinese": "安静的", "phonetic": "/ˈkwaɪət/", "audio": "quiet"},
        {"word": "noisy", "chinese": "吵闹的", "phonetic": "/ˈnɔɪzi/", "audio": "noisy"}
      ],
      "sentences": [
        {"english": "What's that noise?", "chinese": "那是什么噪音？"},
        {"english": "I heard a drill.", "chinese": "我听到了钻孔机的声音。"},
        {"english": "It was too loud.", "chinese": "它太吵了。"},
        {"english": "It was quiet. Now it is noisy.", "chinese": "之前很安静。现在很吵。"}
      ],
      "grammar": [
        {"type": "sentence_reorder", "question": "that / What's / noise / ?", "answer": "What's that noise?", "explanation": "询问噪音：What's that noise?"},
        {"type": "sentence_reorder", "question": "heard / I / a / drill / .", "answer": "I heard a drill.", "explanation": "过去时：主语 + 动词过去式。hear的过去式是heard。"},
        {"type": "logic_match", "question": "将动词与过去式配对：hear, sit, is, are, heard, sat, was, were", "answer": "hear↔heard, sit↔sat, is↔was, are↔were", "explanation": "不规则动词的过去式需要记住。"},
        {"type": "context_fill", "question": "I _____ (hear/heard) a loud noise yesterday.", "answer": "heard", "explanation": "yesterday表示过去，用过去式heard。"}
      ]
    },
