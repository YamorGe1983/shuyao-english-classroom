  "grammar": {
    "choiceQuestions": {
      "basic": [
        {
          "id": "g4a_b_01",
          "question": "She ___ swim very well.",
          "options": [
            "can",
            "cans",
            "can to"
          ],
          "answer": 0,
          "explanation": "can后接动词原形，没有人称和数的变化。"
        },
        {
          "id": "g4a_b_02",
          "question": "___ you paint? Yes, I can.",
          "options": [
            "Can",
            "Do",
            "Does"
          ],
          "answer": 0,
          "explanation": "情态动词can直接提前构成疑问句。"
        },
        {
          "id": "g4a_b_03",
          "question": "This is ___ book.",
          "options": [
            "I",
            "my",
            "me"
          ],
          "answer": 1,
          "explanation": "my是形容词性物主代词，后接名词。"
        },
        {
          "id": "g4a_b_04",
          "question": "___ name is Tom.",
          "options": [
            "His",
            "He",
            "Him"
          ],
          "answer": 0,
          "explanation": "his是形容词性物主代词，修饰名词name。"
        },
        {
          "id": "g4a_b_05",
