  "grammar": {
    "choiceQuestions": {
      "basic": [
        {"id": "g4_b_001", "question": "There ___ a library in your school?", "options": ["Is", "Are", "Do"], "answer": 0, "explanation": "There be疑问句：单数用Is there。"},
        {"id": "g4_b_002", "question": "What ___ your father do? He is a doctor.", "options": ["is", "do", "does"], "answer": 2, "explanation": "询问职业：What does...do?"},
        {"id": "g4_b_003", "question": "How much ___ the apples? They are ten yuan.", "options": ["is", "are", "am"], "answer": 1, "explanation": "apples是复数，用How much are。"},
        {"id": "g4_b_004", "question": "Don't ___ on the grass.", "options": ["walk", "walking", "walks"], "answer": 0, "explanation": "祈使句否定：Don't + 动词原形。"},
        {"id": "g4_b_005", "question": "She ___ sing very well.", "options": ["can", "cans", "is"], "answer": 0, "explanation": "情态动词can后接动词原形。"}
      ],
      "improved": [
        {"id": "g4_i_001", "question": "Can she swim? No, she ___.", "options": ["can't", "isn't", "doesn't"], "answer": 0, "explanation": "can的否定回答用can't。"},
        {"id": "g4_i_002", "question": "What does your mother ___? She is a nurse.", "options": ["do", "does", "is"], "answer": 0, "explanation": "What does...do? 询问职业。"},
        {"id": "g4_i_003", "question": "How ___ is the bread? It's five yuan.", "options": ["many", "much", "old"], "answer": 1, "explanation": "询问价格用How much。"}
