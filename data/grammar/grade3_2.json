    {
      "id": "g3_2_29",
      "type": "E",
      "grammarPoint": "be动词 vs have/has",
      "instruction": "选择正确的词填空",
      "content": {
        "questions": [
          {
            "sentence": "Kitty and I ____ good friends.",
            "options": ["am", "is", "are", "have", "has"],
            "answer": "are",
            "hint": "Kitty and I = 我们俩，是朋友关系'是'，用are"
          },
          {
            "sentence": "Kitty and I ____ new bicycles.",
            "options": ["am", "is", "are", "have", "has"],
            "answer": "have",
            "hint": "我们俩'拥有'自行车，用have"
          },
          {
            "sentence": "The elephant ____ a long nose.",
            "options": ["am", "is", "are", "have", "has"],
            "answer": "has",
            "hint": "大象'有'长鼻子，表示拥有用has"
          },
          {
            "sentence": "The elephant ____ big and grey.",
            "options": ["am", "is", "are", "have", "has"],
            "answer": "is",
            "hint": "大象'是'又大又灰的，表示状态用is"
          }
        ]
      },
      "answer": ["are", "have", "has", "is"],
      "hint": "be动词(am/is/are)表示'是'，have/has表示'有'。朋友关系用be动词，拥有东西用have/has。",
      "difficulty": 2
